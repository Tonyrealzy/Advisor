generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AIPersistedResponse {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    String
  query     Json
  data      Json?
  message   String?
  error     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id])
  @@index([userId])
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  responses        AIPersistedResponse[]
  passwordResets   PasswordReset[]
  session          UserSession?

  @@index([id])
  @@index([email])
  @@index([isActive])
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([id])
  @@index([userId])
}

model UserSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([id])
  @@index([userId])
}