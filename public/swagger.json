    "/api/health": {
      "get": {
        "summary": "Get API health status",
        "description": "Returns the health status of the API.",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "health": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "uptime": {
                          "type": "number"
                        },
                        "email": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
